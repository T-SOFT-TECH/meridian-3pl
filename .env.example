# PocketBase base URL — local dev: http://127.0.0.1:8090; in Docker/VPS: the service name,
# e.g. http://pocketbase:8090 (NOT the public domain). Legacy name PB_URL still accepted.
POCKETBASE_URL="http://127.0.0.1:8090"

# Service account — a normal `users` (staff) record the server authenticates as for
# public quote/contact writes and pricing reads. NOT a superadmin (least privilege).
# Create this account in the PocketBase dashboard, then put its credentials here.
PB_SERVICE_EMAIL="service@meridian3pl.com.au"
PB_SERVICE_PASSWORD="your-service-account-password"

# Outbound email (cPanel mailbox SMTP in production)
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Meridian 3PL <no-reply@meridian3pl.com.au>"

# Where new quote/contact notifications are sent
NOTIFY_TO="info@tsoftechnologies.com"
