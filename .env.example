# PocketBase — local dev points at http://127.0.0.1:8090; production: your cPanel URL/port
PB_URL="http://127.0.0.1:8090"

# PocketBase superadmin credentials (created on first launch of PocketBase)
PB_ADMIN_EMAIL="your-superadmin@email.com"
PB_ADMIN_PASSWORD="your-superadmin-password"

# Outbound email (cPanel mailbox SMTP in production)
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Meridian 3PL <no-reply@meridian3pl.com.au>"

# Where new quote/contact notifications are sent
NOTIFY_TO="info@tsoftechnologies.com"
